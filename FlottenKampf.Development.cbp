<?xml version="1.0" encoding="UTF-8" standalone="yes" ?>
<CodeBlocks_project_file>
	<FileVersion major="1" minor="6" />
	<Project>
		<Option title="FlottenKampf.Development" />
		<Option pch_mode="2" />
		<Option compiler="gcc" />
		<Build>
			<Target title="Debug">
				<Option output="bin/Debug/FlottenKampf" prefix_auto="1" extension_auto="1" />
				<Option object_output="obj/Debug/" />
				<Option type="1" />
				<Option compiler="gcc" />
				<Compiler>
					<Add option="-g" />
					<Add option="-DSFML_STATIC" />
					<Add directory="include" />
				</Compiler>
				<Linker>
					<Add library="sfml-graphics-d" />
					<Add library="sfml-window-d" />
					<Add library="sfml-system-d" />
				</Linker>
			</Target>
			<Target title="Release">
				<Option output="bin/Release/FlottenKampf" prefix_auto="1" extension_auto="1" />
				<Option object_output="obj/Release/" />
				<Option type="1" />
				<Option compiler="gcc" />
				<Compiler>
					<Add option="-O2" />
					<Add directory="include" />
				</Compiler>
				<Linker>
					<Add option="-s" />
					<Add library="sfml-graphics" />
					<Add library="sfml-window" />
					<Add library="sfml-system" />
				</Linker>
			</Target>
		</Build>
		<Compiler>
			<Add option="-Wall" />
			<Add option="-fexceptions" />
			<Add option="-DSFML_STATIC" />
			<Add directory="../../SFML-3.1.0/include" />
		</Compiler>
		<Linker>
			<Add directory="../../SFML-3.1.0/lib" />
		</Linker>
		<Unit filename="include/BattleContext.h" />
		<Unit filename="include/Brig.h" />
		<Unit filename="include/Galleon.h" />
		<Unit filename="include/Game.h" />
		<Unit filename="include/IShip.h" />
		<Unit filename="include/Schooner.h" />
		<Unit filename="include/Ship.h" />
		<Unit filename="include/ShipFactory.h" />
		<Unit filename="include/Team.h" />
		<Unit filename="include/World.h" />
		<Unit filename="main.cpp" />
		<Unit filename="src/BattleContext.cpp" />
		<Unit filename="src/Brig.cpp" />
		<Unit filename="src/Galleon.cpp" />
		<Unit filename="src/Game.cpp" />
		<Unit filename="src/IShip.cpp" />
		<Unit filename="src/Schooner.cpp" />
		<Unit filename="src/Ship.cpp" />
